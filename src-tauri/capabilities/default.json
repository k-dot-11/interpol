{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "Capability for the main window",
    "windows": ["main"],
    "permissions": [
        "core:default",
        "opener:default",
        "log:default",
        {
            "identifier": "fs:allow-write-text-file",
            "allow": [{ "path": "$DOCUMENT/**" }]
        },
        {
            "identifier": "fs:allow-mkdir",
            "allow": [{ "path": "$DOCUMENT/**" }]
        }
    ]
}
